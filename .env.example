# App
APP_NAME=СвойСтиль
DEBUG=False
FRONTEND_URL=https://your-frontend.netlify.app
BACKEND_URL=https://your-backend.onrender.com

# Database (Render PostgreSQL — автоматически из RENDER_DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/svoy_style

# Redis (Render Redis — автоматически из REDIS_URL)
REDIS_URL=redis://host:6379/0

# JWT
SECRET_KEY=change-this-to-random-string-in-production
JWT_REFRESH_SECRET=change-this-too

# GigaChat (опционально — без ключа будет мок-режим)
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Kandinsky (опционально — без ключа будет мок-режим)
KANDINSKY_API_KEY=
KANDINSKY_SECRET_KEY=

# SaluteSpeech (опционально)
SALUTE_AUTH_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
