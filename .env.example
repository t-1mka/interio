# ════════════════════════════════════════
#  Interio — переменные окружения
#  Скопируйте в .env и заполните значения
# ════════════════════════════════════════

# ── GigaChat ИИ-советник ──────────────
# Получить на: https://developers.sber.ru/studio/
# Формат: base64("clientId:clientSecret")  — вставляйте КАК ЕСТЬ, без дополнительного кодирования
GIGACHAT_AUTH_KEY=MDE5ZDUzMWMt...ваш_ключ...ZTk2ZQ==

# ── Telegram-бот ──────────────────────
# Получить у @BotFather: /newbot
TELEGRAM_BOT_TOKEN=8781630278:AAH4LqI...ваш_токен...
# Ваш Telegram chat_id (узнать у @userinfobot)
TELEGRAM_ADMIN_CHAT_ID=123456789

# ── Email уведомления (SMTP) ──────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASSWORD=ваш_пароль_приложения
ADMIN_EMAIL=manager@interio.ru

# ── База данных ───────────────────────
# SQLite (по умолчанию, для разработки и Render free tier):
DATABASE_URL=sqlite:///data.db
# PostgreSQL (для продакшена):
# DATABASE_URL=postgresql://user:password@host:5432/interio

# ── Хранилище файлов ──────────────────
UPLOAD_DIR=uploads

# ── URL сервиса ───────────────────────
FRONTEND_URL=http://localhost:8000
